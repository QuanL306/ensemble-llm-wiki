# ensemble-llm-wiki — LLM API keys
#
# Set exactly ONE of the following. The system auto-detects whichever is present.
# Auto-detection order: DeepSeek → OpenAI → Claude → Gemini → Kimi → Zhipu → MiniMax
#
# DeepSeek  (recommended — cheap, fast, great for Chinese + English)
# DEEPSEEK_API_KEY=sk-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...

# Kimi / Moonshot (China)
# MOONSHOT_API_KEY=sk-...

# Zhipu GLM (China)
# ZHIPU_API_KEY=...

# MiniMax (China)
# MINIMAX_API_KEY=...

# ── Optional overrides ──────────────────────────────────────────────────────

# Force a specific backend instead of auto-detecting from keys present:
# LLM_BACKEND=deepseek

# Use a non-default API base URL (e.g. for proxies or local inference):
# OPENAI_BASE_URL=http://localhost:11434/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Use a specific Python interpreter for the kb wrapper script
# (useful when graphify is installed in a venv that isn't on PATH):
# KB_PYTHON=/path/to/venv/bin/python3

# Root folder containing multiple knowledge bases (for multi-KB mode):
# KB_ROOT=~/knowledge-bases
